      // Validate baseUrl
      if (!this.baseUrl || typeof this.baseUrl !== 'string') {
        return { ok: false, models: [], error: 'Invalid base URL' };
      }
      
      const url = new URL("/api/tags", this.baseUrl);

      return new Promise((resolve, reject) => {
